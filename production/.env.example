# FlowSync Customer Success AI Agent -- Environment Variables
# =============================================================
# Copy this file: cp .env.example .env
# Fill in your actual values.
#
# NEVER commit .env to version control!

# ──────────────────────────────────────────────────────────────
# OpenAI (Required)
# ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-your-openai-key-here
OPENAI_MODEL=gpt-4o

# ──────────────────────────────────────────────────────────────
# PostgreSQL (Required)
# ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://flowsync:flowsync_secret@localhost:5432/flowsync

# ──────────────────────────────────────────────────────────────
# Kafka (Optional -- falls back to direct processing)
# ──────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP=flowsync-message-processor

# ──────────────────────────────────────────────────────────────
# Application
# ──────────────────────────────────────────────────────────────
LOG_LEVEL=info
APP_ENV=development

# ──────────────────────────────────────────────────────────────
# Server
# ──────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ──────────────────────────────────────────────────────────────
# CORS (for local dev with Next.js on port 3000)
# ──────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]
